# DeepSeek API key (required)
DEEPSEEK_API_KEY=sk-...

# Stock data store directory (default: ../stock_data/store)
# STOCK_DATA_STORE_DIR=../stock_data/store

# Web search (optional — get key from https://app.tavily.com/)
# TAVILY_API_KEY=tvly-...
# WEB_SEARCH_ENABLED=true

# --------------------------------------------------------------------------
# Memory (mem0) — Per-user long-term memory
# --------------------------------------------------------------------------

# Enable/disable memory features (default: true)
# MEM0_ENABLED=true

# OpenAI API key — used for memory embeddings (text-embedding-3-small).
# If not set, falls back to local HuggingFace embeddings (slower but free).
# OPENAI_API_KEY=sk-...

# Memory data is stored in data/mem0_qdrant/ (local Qdrant vector store)

# --------------------------------------------------------------------------
# Vision — Image analysis for stock screenshots
# --------------------------------------------------------------------------

# API key for the vision model (required for image support)
VISION_API_KEY=sk-...

# Vision model name (default: gpt-5.2)
# VISION_MODEL=gpt-5.2

# Base URL for the vision model API
# VISION_BASE_URL=https://xxx.com/v1
